<%- include("partials/header") %>

<main id="top">

  <section class="page-hero">

    <p class="section-label">
      GET IN TOUCH
    </p>

    <h1>
      Contact <span>Me</span>
    </h1>

    <p>
      Have a project, opportunity or idea?
      Send me a message and let's connect.
    </p>

  </section>


  <section class="contact-section">

    <div class="contact-information">

      <p class="section-label">
        LET'S CONNECT
      </p>

      <h2>
        Let's build something
        <span>useful together.</span>
      </h2>

      <p class="contact-description">
        I am interested in software development,
        full-stack development, Android development,
        IoT projects, internships and new learning
        opportunities.
      </p>


      <div class="contact-details">

        <article>

          <div class="contact-icon">
            @
          </div>

          <div>

            <small>
              Email
            </small>

            <a
              href="mailto:Ashrafvantiya786@gmail.com"
            >
              Ashrafvantiya786@gmail.com
            </a>

          </div>

        </article>


        <article>

          <div class="contact-icon">
            ⌖
          </div>

          <div>

            <small>
              Location
            </small>

            <p>
              Ahmedabad, Gujarat, India
            </p>

          </div>

        </article>


        <article>

          <div class="contact-icon">
            GH
          </div>

          <div>

            <small>
              GitHub
            </small>

            <a
              href="https://github.com/ashrafvantiya"
              target="_blank"
              rel="noopener noreferrer"
            >
              github.com/ashrafvantiya
            </a>

          </div>

        </article>


        <article>

          <div class="contact-icon">
            in
          </div>

          <div>

            <small>
              LinkedIn
            </small>

            <a
              href="https://www.linkedin.com/in/ashraf-vantiya-475624"
              target="_blank"
              rel="noopener noreferrer"
            >
              Connect on LinkedIn
            </a>

          </div>

        </article>

      </div>

    </div>


    <div class="contact-form-container">

      <div class="form-heading">

        <p class="section-label">
          SEND A MESSAGE
        </p>

        <h2>
          Tell me about
          <span>your idea.</span>
        </h2>

      </div>


      <% if (success) { %>

        <div
          class="form-alert success-alert"
          role="alert"
        >

          <strong>
            Message sent successfully!
          </strong>

          <p>
            Thank you for contacting me.
            I will get back to you soon.
          </p>

        </div>

      <% } %>


      <% if (error) { %>

        <div
          class="form-alert error-alert"
          role="alert"
        >

          <strong>
            Message could not be sent.
          </strong>

          <p>
            <%= error %>
          </p>

        </div>

      <% } %>


      <form
        action="/contact"
        method="POST"
        class="contact-form"
        id="contactForm"
      >

        <div class="form-group">

          <label for="name">
            Your Name
          </label>

          <input
            type="text"
            id="name"
            name="name"
            placeholder="Enter your full name"
            minlength="2"
            maxlength="60"
            autocomplete="name"
            required
          >

        </div>


        <div class="form-group">

          <label for="email">
            Email Address
          </label>

          <input
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email address"
            maxlength="120"
            autocomplete="email"
            required
          >

        </div>


        <div class="form-group">

          <label for="message">
            Your Message
          </label>

          <textarea
            id="message"
            name="message"
            placeholder="Tell me about your project or opportunity..."
            minlength="10"
            maxlength="1500"
            rows="7"
            required
          ></textarea>

          <small class="character-counter">

            <span id="messageCharacters">
              0
            </span>

            / 1500 characters

          </small>

        </div>


        <button
          type="submit"
          class="primary-button submit-button"
          id="submitButton"
        >

          <span class="button-text">
            Send Message
          </span>

          <span class="button-arrow">
            →
          </span>

        </button>

      </form>

    </div>

  </section>


  <section class="availability-section">

    <div class="availability-status">

      <span class="status-dot"></span>

      <p>
        Available for internships,
        projects and development opportunities.
      </p>

    </div>

  </section>

</main>

<%- include("partials/footer") %>